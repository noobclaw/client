{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "NoobClaw",
  "version": "1.0.0",
  "identifier": "com.noobclaw.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev -- --port 5175",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5175"
  },
  "app": {
    "windows": [
      {
        "title": "NoobClaw",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/noobclaw-server"
    ],
    "resources": [
      "../SKILLs/**/*",
      "../chrome-extension/**/*",
      "../resources/tray/**/*"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/noobclaw-server",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
