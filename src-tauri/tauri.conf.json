{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "NoobClaw",
  "version": "1.0.0",
  "identifier": "com.noobclaw.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev -- --port 5175",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5175"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "NoobClaw",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: tauri: https: http:; img-src 'self' data: blob: https: http:; connect-src 'self' https: http: ws: wss: tauri:; font-src 'self' data: https:; media-src 'self' https: http: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/noobclaw-server"
    ],
    "resources": [
      "../SKILLs/**/*",
      "../chrome-extension/**/*",
      "../resources/tray/**/*",
      "../sandbox/agent-runner/AGENT_SYSTEM_PROMPT.md",
      "binaries/sql-wasm.wasm"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "headerImage": null
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["noobclaw"]
      }
    }
  }
}
